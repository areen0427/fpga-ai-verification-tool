{
  "name": "fpga-ai-verification-tool",
  "displayName": "FPGA AI Verification Tool",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "fpga-ai-verification-tool.analyzeFile",
        "title": "Analyze Current FPGA File"
      },
      {
        "command": "fpga-ai-verification-tool.analyzeWorkspace",
        "title": "Analyze FPGA Workspace"
      }
    ],

    "viewsContainers": {
      "activitybar": [
        {
          "id": "fpgaVerifier",
          "title": "FPGA Verifier",
          "icon": "media/icon.svg"
        }
      ]
    },

    "views": {
      "fpgaVerifier": [
        {
          "id": "fpgaVerifierResults",
          "name": "Verification Results"
        }
      ]
    }
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },

  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}